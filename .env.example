# LLM API Configuration (OpenAI-compatible)
# Copy this file to .env and fill in your credentials.

# Your API endpoint URL (e.g., OpenAI, Azure, or local LLM proxy)
VITE_LLM_API_URL=https://api.openai.com/v1/chat/completions

# Your API key
VITE_LLM_API_KEY=sk-your-key-here

# Optional: model name (default: gpt-4o-mini)
VITE_LLM_MODEL=gpt-4o-mini
